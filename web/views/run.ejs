<!DOCTYPE html>
<html>
<head>
  <title>Run <%= run.run_id %></title>
</head>
<body>

<h1>Run <%= run.run_id %></h1>

<p>Status: <strong id="status"><%= run.status %></strong></p>

<% if (run.status === "running") { %>
<script>
  const interval = setInterval(async () => {
    const res = await fetch("/api/status/<%= run.run_id %>");
    const data = await res.json();

    document.getElementById("status").innerText = data.status;

    if (data.status !== "running") {
      clearInterval(interval);
      location.reload();
    }
  }, 2000);
</script>
<% } %>

<% if (run.status === "passed") { %>
  <p>
    <a href="/report/<%= run.run_id %>/index.html" target="_blank">
      Open Allure Report
    </a>
  </p>
<% } %>

<p><a href="/runs">Back to history</a></p>

</body>
</html>